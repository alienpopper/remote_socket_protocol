BORINGSSL_SOURCE_DIR ?= third_party/boringssl
BORINGSSL_INCLUDE_DIR := $(BORINGSSL_SOURCE_DIR)/include
BORINGSSL_INCLUDE_HEADER := $(BORINGSSL_INCLUDE_DIR)/openssl/evp.h
PROTOBUF_SOURCE_DIR ?= third_party/protobuf
PROTOBUF_CMAKE_SOURCE_DIR := $(PROTOBUF_SOURCE_DIR)
PROTOBUF_INCLUDE_DIR := $(PROTOBUF_SOURCE_DIR)/src
PROTOBUF_INCLUDE_HEADER := $(PROTOBUF_INCLUDE_DIR)/google/protobuf/message_lite.h
PROTOBUF_VERSION := v29.6
PROTOBUF_VERSION_STAMP := $(PROTOBUF_SOURCE_DIR)/.copilot-protobuf-$(PROTOBUF_VERSION)
NLOHMANN_JSON_SOURCE_DIR ?= third_party/json
NLOHMANN_JSON_INCLUDE_DIR := $(NLOHMANN_JSON_SOURCE_DIR)/single_include
NLOHMANN_JSON_INCLUDE_HEADER := $(NLOHMANN_JSON_INCLUDE_DIR)/nlohmann/json.hpp
NLOHMANN_JSON_VERSION := v3.12.0
NLOHMANN_JSON_VERSION_STAMP := $(NLOHMANN_JSON_SOURCE_DIR)/.copilot-nlohmann-json-$(NLOHMANN_JSON_VERSION)

UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
	BORINGSSL_BUILD_DIR := $(BORINGSSL_SOURCE_DIR)/build-osx
	PROTOBUF_BUILD_DIR := $(PROTOBUF_SOURCE_DIR)/build-osx-debug
	PROTOBUF_INSTALL_DIR := $(PROTOBUF_SOURCE_DIR)/install-osx
else
	BORINGSSL_BUILD_DIR := $(BORINGSSL_SOURCE_DIR)/build-linux
	PROTOBUF_BUILD_DIR := $(PROTOBUF_SOURCE_DIR)/build-linux-debug
	PROTOBUF_INSTALL_DIR := $(PROTOBUF_SOURCE_DIR)/install-linux
endif

BORINGSSL_CRYPTO_LIB := $(BORINGSSL_BUILD_DIR)/libcrypto.a
BORINGSSL_CMAKE_FLAGS := -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF
PROTOBUF_LITE_LIB := $(PROTOBUF_INSTALL_DIR)/lib/protobuf_combined.a
PROTOBUF_PROTOC := $(PROTOBUF_INSTALL_DIR)/bin/protoc
PROTOBUF_PROTOC_LIB := $(PROTOBUF_INSTALL_DIR)/lib/libprotoc.a
ABSEIL_INCLUDE_DIR := $(PROTOBUF_INSTALL_DIR)/include
PROTOBUF_CMAKE_FLAGS := -DCMAKE_BUILD_TYPE=Debug -Dprotobuf_BUILD_TESTS=OFF -Dprotobuf_BUILD_EXAMPLES=OFF -DBUILD_SHARED_LIBS=OFF -Dprotobuf_WITH_ZLIB=OFF -Dprotobuf_ABSL_PROVIDER=module -DABSL_PROPAGATE_CXX_STD=ON -DCMAKE_INSTALL_PREFIX=$(PROTOBUF_INSTALL_DIR)

$(BORINGSSL_INCLUDE_HEADER):
	@if [ ! -d "$(BORINGSSL_SOURCE_DIR)/.git" ]; then git clone https://github.com/google/boringssl.git $(BORINGSSL_SOURCE_DIR); fi

$(BORINGSSL_CRYPTO_LIB): $(BORINGSSL_INCLUDE_HEADER)
	cmake -S $(BORINGSSL_SOURCE_DIR) -B $(BORINGSSL_BUILD_DIR) $(BORINGSSL_CMAKE_FLAGS)
	cmake --build $(BORINGSSL_BUILD_DIR) --target crypto --parallel 2

$(PROTOBUF_VERSION_STAMP):
	@if [ -d "$(PROTOBUF_SOURCE_DIR)/.git" ]; then \
		git -C $(PROTOBUF_SOURCE_DIR) fetch --depth 1 origin refs/tags/$(PROTOBUF_VERSION):refs/tags/$(PROTOBUF_VERSION); \
		git -C $(PROTOBUF_SOURCE_DIR) checkout --force $(PROTOBUF_VERSION); \
		git -C $(PROTOBUF_SOURCE_DIR) submodule update --init --depth 1; \
	else \
		git clone --branch $(PROTOBUF_VERSION) --depth 1 --recurse-submodules --shallow-submodules https://github.com/protocolbuffers/protobuf.git $(PROTOBUF_SOURCE_DIR); \
	fi
	rm -rf $(PROTOBUF_BUILD_DIR) $(PROTOBUF_INSTALL_DIR)
	@touch $(PROTOBUF_VERSION_STAMP)

$(PROTOBUF_INCLUDE_HEADER): $(PROTOBUF_VERSION_STAMP)

$(NLOHMANN_JSON_VERSION_STAMP):
	@if [ -d "$(NLOHMANN_JSON_SOURCE_DIR)/.git" ]; then \
		git -C $(NLOHMANN_JSON_SOURCE_DIR) fetch --depth 1 origin refs/tags/$(NLOHMANN_JSON_VERSION):refs/tags/$(NLOHMANN_JSON_VERSION); \
		git -C $(NLOHMANN_JSON_SOURCE_DIR) checkout --force $(NLOHMANN_JSON_VERSION); \
	else \
		git clone --branch $(NLOHMANN_JSON_VERSION) --depth 1 https://github.com/nlohmann/json.git $(NLOHMANN_JSON_SOURCE_DIR); \
	fi
	@touch $(NLOHMANN_JSON_VERSION_STAMP)

$(NLOHMANN_JSON_INCLUDE_HEADER): $(NLOHMANN_JSON_VERSION_STAMP)

$(PROTOBUF_LITE_LIB): $(PROTOBUF_INCLUDE_HEADER)
	cmake -S $(PROTOBUF_CMAKE_SOURCE_DIR) -B $(PROTOBUF_BUILD_DIR) $(PROTOBUF_CMAKE_FLAGS)
	cmake --build $(PROTOBUF_BUILD_DIR) --parallel 2
	cmake --install $(PROTOBUF_BUILD_DIR)
	python3 scripts/combine_protobuf_libs.py $(PROTOBUF_INSTALL_DIR)/lib $(PROTOBUF_LITE_LIB)

$(PROTOBUF_PROTOC): $(PROTOBUF_LITE_LIB)