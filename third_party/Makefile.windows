BORINGSSL_SOURCE_DIR = third_party\boringssl
BORINGSSL_INCLUDE_DIR = $(BORINGSSL_SOURCE_DIR)\include
BORINGSSL_INCLUDE_HEADER = $(BORINGSSL_INCLUDE_DIR)\openssl\evp.h
BORINGSSL_BUILD_DIR = $(BORINGSSL_SOURCE_DIR)\build-windows
BORINGSSL_CRYPTO_LIB = $(BORINGSSL_BUILD_DIR)\crypto.lib
BORINGSSL_CMAKE_FLAGS = -G "NMake Makefiles" -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF -DOPENSSL_NO_ASM=1
PROTOBUF_SOURCE_DIR = third_party\protobuf
PROTOBUF_CMAKE_SOURCE_DIR = $(PROTOBUF_SOURCE_DIR)\cmake
PROTOBUF_INCLUDE_DIR = $(PROTOBUF_SOURCE_DIR)\src
PROTOBUF_INCLUDE_HEADER = $(PROTOBUF_INCLUDE_DIR)\google\protobuf\message_lite.h
PROTOBUF_BUILD_DIR = $(PROTOBUF_SOURCE_DIR)\build-windows
PROTOBUF_LITE_LIB = $(PROTOBUF_BUILD_DIR)\libprotobuf.lib
PROTOBUF_PROTOC = $(PROTOBUF_BUILD_DIR)\protoc.exe
PROTOBUF_VERSION = v3.20.3
PROTOBUF_VERSION_STAMP = $(PROTOBUF_SOURCE_DIR)\.copilot-protobuf-$(PROTOBUF_VERSION)
PROTOBUF_CMAKE_FLAGS = -G "NMake Makefiles" -DCMAKE_BUILD_TYPE=Release -Dprotobuf_BUILD_TESTS=OFF -Dprotobuf_BUILD_EXAMPLES=OFF -Dprotobuf_BUILD_SHARED_LIBS=OFF -Dprotobuf_WITH_ZLIB=OFF -Dprotobuf_MSVC_STATIC_RUNTIME=OFF
NLOHMANN_JSON_SOURCE_DIR = third_party\json
NLOHMANN_JSON_INCLUDE_DIR = $(NLOHMANN_JSON_SOURCE_DIR)\single_include
NLOHMANN_JSON_INCLUDE_HEADER = $(NLOHMANN_JSON_INCLUDE_DIR)\nlohmann\json.hpp
NLOHMANN_JSON_VERSION = v3.12.0
NLOHMANN_JSON_VERSION_STAMP = $(NLOHMANN_JSON_SOURCE_DIR)\.copilot-nlohmann-json-$(NLOHMANN_JSON_VERSION)

$(BORINGSSL_INCLUDE_HEADER):
	if not exist $(BORINGSSL_SOURCE_DIR)\include\openssl\evp.h git clone https://github.com/google/boringssl.git $(BORINGSSL_SOURCE_DIR)

$(BORINGSSL_CRYPTO_LIB): $(BORINGSSL_INCLUDE_HEADER)
	cmake -S $(BORINGSSL_SOURCE_DIR) -B $(BORINGSSL_BUILD_DIR) $(BORINGSSL_CMAKE_FLAGS)
	cmake --build $(BORINGSSL_BUILD_DIR) --target crypto

$(PROTOBUF_VERSION_STAMP):
	if exist $(PROTOBUF_SOURCE_DIR)\.git (git -C $(PROTOBUF_SOURCE_DIR) fetch --depth 1 origin refs/tags/$(PROTOBUF_VERSION):refs/tags/$(PROTOBUF_VERSION) && git -C $(PROTOBUF_SOURCE_DIR) checkout --force $(PROTOBUF_VERSION)) else (git clone --branch $(PROTOBUF_VERSION) --depth 1 https://github.com/protocolbuffers/protobuf.git $(PROTOBUF_SOURCE_DIR))
	if exist $(PROTOBUF_BUILD_DIR) rmdir /S /Q $(PROTOBUF_BUILD_DIR)
	type nul > $(PROTOBUF_VERSION_STAMP)

$(PROTOBUF_INCLUDE_HEADER): $(PROTOBUF_VERSION_STAMP)

$(NLOHMANN_JSON_VERSION_STAMP):
	if exist $(NLOHMANN_JSON_SOURCE_DIR)\.git (git -C $(NLOHMANN_JSON_SOURCE_DIR) fetch --depth 1 origin refs/tags/$(NLOHMANN_JSON_VERSION):refs/tags/$(NLOHMANN_JSON_VERSION) && git -C $(NLOHMANN_JSON_SOURCE_DIR) checkout --force $(NLOHMANN_JSON_VERSION)) else (git clone --branch $(NLOHMANN_JSON_VERSION) --depth 1 https://github.com/nlohmann/json.git $(NLOHMANN_JSON_SOURCE_DIR))
	type nul > $(NLOHMANN_JSON_VERSION_STAMP)

$(NLOHMANN_JSON_INCLUDE_HEADER): $(NLOHMANN_JSON_VERSION_STAMP)

$(PROTOBUF_LITE_LIB): $(PROTOBUF_INCLUDE_HEADER)
	cmake -S $(PROTOBUF_CMAKE_SOURCE_DIR) -B $(PROTOBUF_BUILD_DIR) $(PROTOBUF_CMAKE_FLAGS)
	cmake --build $(PROTOBUF_BUILD_DIR) --target libprotobuf protoc

$(PROTOBUF_PROTOC): $(PROTOBUF_LITE_LIB)