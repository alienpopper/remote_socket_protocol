generate-messages: messages.proto $(GENERATE_MESSAGES_SCRIPT)
	python $(GENERATE_MESSAGES_SCRIPT) --proto messages.proto --nodejs $(NODEJS_MESSAGES_JS) --python $(PYTHON_MESSAGES_PY)

$(OBJ_DIR)\base_types.obj: common\base_types.cpp common\base_types.hpp
	cl $(CPPFLAGS) $(CXXFLAGS) /c common\base_types.cpp /Fo$(OBJ_DIR)\base_types.obj

$(OBJ_DIR)\node.obj: common\node.cpp common\node.hpp $(OS_HEADER) $(PROTOBUF_GENERATED_HEADER)
	cl $(CPPFLAGS) $(CXXFLAGS) /c common\node.cpp /Fo$(OBJ_DIR)\node.obj

