PROJECT_ROOT = .
BUILD_DIR = build
BIN_DIR = $(BUILD_DIR)\bin
OBJ_DIR = $(BUILD_DIR)\obj
LIB_DIR = $(BUILD_DIR)\lib
PROTOBUF_GENERATED_DIR = $(BUILD_DIR)\gen
TARGET = $(BIN_DIR)\resource_manager.exe
KEYPAIR_TEST_TARGET = $(BIN_DIR)\keypair_test.exe
BASE_TYPES_TEST_TARGET = $(BIN_DIR)\base_types_test.exe
CLIENT_TEST_TARGET = $(BIN_DIR)\client_test.exe
ENDORSEMENT_TEST_TARGET = $(BIN_DIR)\endorsement_test.exe
MESSAGE_QUEUE_TEST_TARGET = $(BIN_DIR)\message_queue_test.exe
MQ_ASCII_HANDSHAKE_TEST_TARGET = $(BIN_DIR)\mq_ascii_handshake_test.exe
MQ_SIGNING_TEST_TARGET = $(BIN_DIR)\mq_signing_test.exe
MQ_AUTHN_TEST_TARGET = $(BIN_DIR)\mq_authn_test.exe
MQ_AUTHZ_TEST_TARGET = $(BIN_DIR)\mq_authz_test.exe
RSP_ENDORSEMENT_TOOL_TARGET = $(BIN_DIR)\rsp_endorsement.exe
NODE_TEST_TARGET = $(BIN_DIR)\node_test.exe
RESOURCE_SERVICE_TEST_TARGET = $(BIN_DIR)\resource_service_test.exe
RESOURCE_SERVICE_JSON_TEST_TARGET = $(BIN_DIR)\resource_service_json_test.exe
RESOURCE_SERVICE_TARGET = $(BIN_DIR)\resource_service.exe
ENDORSEMENT_SERVICE_TEST_TARGET = $(BIN_DIR)\endorsement_service_test.exe
