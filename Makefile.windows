MESSAGE_HASH_TEST_TARGET = $(BIN_DIR)\message_hash_test.exe
RSPCLIENT_STATIC_TARGET = $(LIB_DIR)\rspclient_static.lib
RSPFULLCLIENT_STATIC_TARGET = $(LIB_DIR)\rspclient_full_static.lib
RSPCLIENT_IMPORT_LIB = $(LIB_DIR)\rspclient.lib
RSPCLIENT_SHARED_TARGET = $(BIN_DIR)\rspclient.dll
PROTOBUF_GENERATED_SOURCE = $(PROTOBUF_GENERATED_DIR)\messages.pb.cc
PROTOBUF_GENERATED_HEADER = $(PROTOBUF_GENERATED_DIR)\messages.pb.h
PROTOBUF_GENERATED_OBJECT = $(OBJ_DIR)\messages.pb.obj
GENERATE_MESSAGES_SCRIPT = scripts\generate_messages.py
NODEJS_MESSAGES_JS = client\nodejs\messages.js
PYTHON_MESSAGES_PY = client\python\messages.py

!include common\Makefile
!include os\Makefile.windows
!include client\cpp\Makefile
!include client\cpp_full\Makefile

CPPFLAGS = /I$(PROJECT_ROOT) /nologo /EHsc /std:c++17
CXXFLAGS = /W4 /MD

SOURCES = \
	$(COMMON_BASE_TYPES_SOURCE) \
	$(COMMON_NODE_SOURCE) \
	$(COMMON_KEYPAIR_SOURCE) \
	$(COMMON_MESSAGE_QUEUE_SOURCE) \
