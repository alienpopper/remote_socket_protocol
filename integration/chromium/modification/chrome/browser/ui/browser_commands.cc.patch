+
+void NewRspTab(BrowserWindowInterface* browser, const GURL& url) {
+  CHECK(browser);
+  base::RecordAction(base::UserMetricsAction("NewRspTab"));
+
+  // TODO(rsp): Show RspTabConfigDialog to let the user choose RM/RS.
+  // For now, use the configured defaults. Without an RS node ID, the tab still
+  // opens and navigates normally, but HTTP requests are not routed through RSP.
+  RspTabConfig config;
+  const std::string& default_rm =
+      browser->GetProfile()->GetOriginalProfile()->GetPrefs()->GetString(
+          rsp::prefs::kRspDefaultRmAddr);
+  const std::string& default_rs_node_id =
+      browser->GetProfile()->GetOriginalProfile()->GetPrefs()->GetString(
+          rsp::prefs::kRspDefaultRsNodeId);
+  config.rm_addr = default_rm.empty() ? "127.0.0.1:3939" : default_rm;
+  config.rs_node_id = default_rs_node_id;
+
+  std::string rsp_conn_key;
+  if (!config.rs_node_id.empty()) {
+    rsp_conn_key = RspConnectionManager::GetInstance()->GetOrCreate(config);
+  }
+
+  Profile* rsp_profile = browser->GetProfile()->GetOriginalProfile()
+      ->GetOffTheRecordProfile(
+          Profile::OTRProfileID::CreateUniqueForRspTab(),
+          /*create_if_needed=*/true);
+
+  if (!rsp_conn_key.empty()) {
+    RspConnectionManager::GetInstance()->RegisterProfile(
+        rsp_profile, rsp_conn_key);
+  }
+
+  const GURL navigation_url = url.is_empty() ? GURL("chrome://newtab") : url;
+  NavigateParams params(browser->GetBrowserForMigrationOnly(),
+                        navigation_url,
+                        ui::PAGE_TRANSITION_AUTO_TOPLEVEL);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  params.initiating_profile = rsp_profile;
+  Navigate(&params);
+}
+
