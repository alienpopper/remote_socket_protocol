+Profile* GetRspProfileForTab(const tabs::TabHandle& tab_handle) {
+  tabs::TabInterface* const tab_interface = tab_handle.Get();
+  content::WebContents* const contents =
+      tab_interface ? tab_interface->GetContents() : nullptr;
+  Profile* const profile = contents ? Profile::FromBrowserContext(
+                                          contents->GetBrowserContext())
+                                    : nullptr;
+  return profile && profile->IsOffTheRecord() &&
+                 profile->GetOTRProfileID().IsRspTab()
+             ? profile
+             : nullptr;
+}
