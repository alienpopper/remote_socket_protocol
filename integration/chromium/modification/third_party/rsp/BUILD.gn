#
# This directory is expected to be a symlink to (or checkout of) the
# remote_socket_protocol repo root.  The config below makes the RSP headers
# and prebuilt RSP client library available to Chromium targets.
#
# To set up:
#   ln -s /path/to/remote_socket_protocol \
#         chromium/src/third_party/rsp

config("rsp_client_config") {
  # RSP repo root (= the symlink target) provides include paths:
  #   client/cpp/rsp_client.hpp     -> "client/cpp/rsp_client.hpp"
  #   common/base_types.hpp         -> "common/base_types.hpp"
  #   build/gen/messages.pb.h       -> included transitively
  include_dirs = [
    ".",          # repo root (client/, common/, os/, ...)
    "build/gen",  # generated protobuf headers (messages.pb.h, etc.)
  ]

  lib_dirs = [ "build/lib" ]
  if (is_win) {
    # Makefile.windows produces build/lib/rspclient.lib (import lib) and
    # build/bin/rspclient.dll.
    libs = [ "rspclient.lib" ]
  } else {
    libs = [ "rspclient" ]
  }

  # Runtime library search path for Linux shared library builds.
  if (is_linux) {
    ldflags = [ "-Wl,-rpath,${root_build_dir}/rsp_lib" ]
  }
}

group("rsp_client") {
  public_configs = [ ":rsp_client_config" ]
}
